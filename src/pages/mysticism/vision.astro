      <a class="link-blue" href="/mysticism">back to mysticism index</a>
      <a class="link-blue" href="/mysticism/revelation">continue to: revelation</a>
      <a class="link-red" href="/mysticism/synchronicity">synchronicity</a>
    </div>
  </Article>
</Layout>
