---
const pageTitle = "Foundations";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <style>
      :root {
        --paper: #ffffff;
        --ink: #000000;
        --line: #000000;
        --soft: #efefef;
        --blue: #0000ee;
        --red: #cc0000;
        --green: #008000;
      }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: "Times New Roman", Times, serif;
        font-size: 18px;
        line-height: 1.55;
      }

      a { text-decoration: underline; }
      a.blue { color: var(--blue); }
      a.red { color: var(--red); }
      a.green { color: var(--green); }

      .page {
        width: min(900px, calc(100% - 48px));
        margin: 0 auto;
        padding: 28px 0 60px;
      }

      .topbar {
        border: 1px solid var(--line);
        padding: 10px 14px;
        margin-bottom: 18px;
        text-align: center;
        background: #fafafa;
      }

      .frame {
        border: 1px solid var(--line);
        padding: 22px 24px 28px;
      }

      h1 {
        font-size: 40px;
        text-align: center;
        margin: 0 0 8px;
      }

      .subtitle {
        text-align: center;
        font-size: 16px;
        margin-bottom: 24px;
      }

      .divider {
        text-align: center;
        margin: 18px 0 24px;
      }

      .section {
        text-align: center;
        margin: 18px 0;
      }

      .section a {
        display: block;
        margin: 6px 0;
      }

      .footer-note {
        text-align: center;
        margin-top: 26px;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="topbar">
        [ <a class="blue" href="/">home</a> ]
        [ <a class="red" href="/symbols/fool">symbols</a> ]
        [ <a class="green" href="/self/creativity-and-fantasy">self</a> ]
      </div>

      <main class="frame">
        <h1>Foundations</h1>
        <p class="subtitle">core structure / psyche / archive index</p>

        <div class="divider">***</div>

        <div class="section">
          <a class="blue" href="/foundations/what-is-the-self">what is the self</a>
          <a class="red" href="/foundations/ego">ego</a>
          <a class="green" href="/foundations/persona">persona</a>
        </div>

        <div class="section">
          <a class="blue" href="/foundations/conscious-and-unconscious">conscious and unconscious</a>
          <a class="red" href="/foundations/individuation">individuation</a>
          <a class="green" href="/foundations/shadow-projection">shadow projection</a>
        </div>

        <div class="footer-note">
          this is the base layer. everything else builds from here.
        </div>
      </main>
    </div>
  </body>
</html>